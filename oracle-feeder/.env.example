# --- Chain config (same as the hackathon repo's .env.local) ---
WIREFLUID_RPC_URL=https://evm.wirefluid.com

# The aggregator-EOA key for PlayerThresholdFeed.pushStat — same deployer key
# used when DeployAll.s.sol ran. In production this would be a DON node key
# whose signature is verified by the Aggregator contract.
PRIVATE_KEY=0x5dcd2005cce156299b843777824e8cd10c8c0920dd55718b10e40a2c2ca405ab

PLAYER_THRESHOLD_FEED=0x1B0F274DE9f1A59f547bfC0350821d0079251efD

# --- Feed mode ---
# Choose one of:
#   simulated  — scripted 80-second match, predictable timing, no API needed
#   cricapi    — polls api.cricapi.com for a real match
FEED_MODE=simulated

# --- CricAPI (only needed when FEED_MODE=cricapi) ---
# Sign up free at https://cricapi.com/ to get a key (100 req/day free tier).
CRICAPI_KEY=
# CricAPI internal match id to poll. Find live matches at
#   https://api.cricapi.com/v1/currentMatches?apikey=YOUR_KEY
CRICAPI_MATCH_ID=

# CricAPI player-id → our canonical playerId. Multiple players OK
# (comma-separated pairs of CRIC_ID:LABEL). The label is what we keccak256
# to get the on-chain bytes32 id, so it must match the DeployAll seed.
# Example:
#   CRICAPI_PLAYER_MAP=abc-123:PAK-KPK-U17-RASHID-001
CRICAPI_PLAYER_MAP=

# Poll interval in seconds (CricAPI free tier = 100 req/day, so >= 30 is safe)
POLL_INTERVAL_SEC=30
